# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/powerplant?schema=public"

# NextAuth v5
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"

# Public base URL used for QR code generation
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Private S3-compatible storage for uploads/backups (server-side only)
S3_ENDPOINT="https://s3.example.com"
S3_REGION="auto"
S3_BUCKET="duyenhai1-uploads"
S3_ACCESS_KEY="replace-with-access-key"
S3_SECRET_KEY="replace-with-secret-key"

# Upload limits
USER_UPLOAD_MAX_FILE_MB="5"
USER_UPLOAD_MAX_ZIP_MB="100"
USER_IMPORT_MAX_FILE_MB="5"

# One-time user import/upload tool. Turn both off after initial production import.
USER_IMPORT_ENABLED="false"
NEXT_PUBLIC_USER_IMPORT_ENABLED="false"
