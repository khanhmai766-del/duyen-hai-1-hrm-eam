// PowerPlant HRM & EAM — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  name                String
  employeeId          String    @unique
  email               String    @unique
  workEmail           String?   @map("work_email")
  username            String?   @unique
  phone               String?
  avatarUrl           String?
  signatureUrl        String? // chữ ký số: PNG nền trong suốt (base64) hoặc URL ngoài
  avatarKey           String?   @map("avatar_key") // S3 object key, không lưu file thật trong DB
  signatureKey        String?   @map("signature_key") // S3 object key, không lưu signed URL cố định
  passwordHash        String
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  passwordChangedAt   DateTime  @default(now()) @map("password_changed_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedAt            DateTime? @map("locked_at")
  role                Role      @default(VIEWER)
  position            String? // e.g. "Lò trưởng S1", "I&C", "Trưởng ca"
  secondaryPosition   String? // chức vụ phụ 1
  secondaryPosition2  String? // chức vụ phụ 2
  currentPosition     String? // chức vụ hiện tại người dùng đang chọn để nhận thông báo/quyền theo cương vị
  department          String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())

  checkIns                 CheckIn[]
  shiftAssignments         ShiftAssignment[]
  repairLogs               RepairLog[]                  @relation("CreatedBy")
  approvedLogs             RepairLog[]                  @relation("ApprovedBy")
  auditLogs                AuditLog[]
  operationEvents          OperationEvent[]             @relation("OpCreatedBy")
  hcGroups                 HcGroup[]                    @relation("HcGroupCreator")
  hcCheckIns               HcCheckIn[]                  @relation("HcCheckInUser")
  announcements            Announcement[]               @relation("AnnouncementCreator")
  announcementReads        AnnouncementRead[]           @relation("AnnouncementReader")
  materialReplacements     MaterialReplacement[]        @relation("MrCreatedBy")
  materialReplacementLogs  MaterialReplacementLog[]     @relation("MrDoneBy")
  defects                  Defect[]                     @relation("DefectCreatedBy")
  defectHistories          DefectHistory[]              @relation("DefectHistoryCreatedBy")
  webAuthnCredentials      WebAuthnCredential[]
  forumPosts               ForumPost[]                  @relation("ForumPostAuthor")
  forumReplies             ForumReply[]                 @relation("ForumReplyAuthor")
  forumPostLikes           ForumPostLike[]              @relation("ForumPostLikeUser")
  forumReplyLikes          ForumReplyLike[]             @relation("ForumReplyLikeUser")
  shiftStaffingAssignments ShiftStaffingAssignment[]    @relation("ShiftStaffingUser")
  shiftStaffingCreated     ShiftStaffingAssignment[]    @relation("ShiftStaffingCreatedBy")
  shiftStaffingUpdated     ShiftStaffingAssignment[]    @relation("ShiftStaffingUpdatedBy")
  shiftPositionCreated     ShiftPositionConfig[]        @relation("ShiftPositionCreatedBy")
  shiftPositionUpdated     ShiftPositionConfig[]        @relation("ShiftPositionUpdatedBy")
  rotationTemplatesCreated RotationTemplate[]           @relation("RotationTemplateCreatedBy")
  rotationTemplatesUpdated RotationTemplate[]           @relation("RotationTemplateUpdatedBy")
  positionRotationsCreated PositionRotationAssignment[] @relation("PositionRotationCreatedBy")
  positionRotationsUpdated PositionRotationAssignment[] @relation("PositionRotationUpdatedBy")
  crewRotationsCreated     CrewRotationConfig[]         @relation("CrewRotationCreatedBy")
  crewRotationsUpdated     CrewRotationConfig[]         @relation("CrewRotationUpdatedBy")
  staffingChangesCreated   StaffingChangeEvent[]        @relation("StaffingChangeCreatedBy")
  scheduleVersionsCreated  ShiftScheduleVersion[]       @relation("ScheduleVersionCreatedBy")
  scheduleVersionsApproved ShiftScheduleVersion[]       @relation("ScheduleVersionApprovedBy")

  @@index([position])
  @@index([role])
  @@index([isActive])
}

model WebAuthnCredential {
  id           String    @id @default(cuid())
  credentialId String    @unique
  publicKey    String
  counter      Int       @default(0)
  userId       String
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Bảng tin nội bộ: bài đăng do Quản trị (ADMIN) tạo, mọi người chỉ xem.
model Announcement {
  id             String    @id @default(cuid())
  category       String    @default("BULLETIN") // BULLETIN (bảng tin) | ORDER (mệnh lệnh sản xuất)
  classification String? // phân loại: Vận hành | An toàn vệ sinh lao động
  stt            String? // số thứ tự (tuỳ chọn), vd "01"
  title          String
  body           String
  pinned         Boolean   @default(false)
  orderedBy      String? // "Theo lệnh" — tên quản đốc / phó quản đốc ra lệnh
  issuedAt       DateTime? // ngày ra mệnh lệnh
  invalidatedAt  DateTime? // ngày đánh dấu mệnh lệnh không còn hiệu lực; tự xoá sau 15 ngày
  linkUrl        String? // optional website link
  fileUrl        String? // optional attached PDF (public URL)
  fileName       String? // original PDF file name
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdBy User               @relation("AnnouncementCreator", fields: [createdById], references: [id])
  reads     AnnouncementRead[]

  @@index([category, pinned, createdAt])
  @@index([pinned, issuedAt, createdAt]) // khớp orderBy của GET /api/announcements
  @@index([createdById])
}

// Xác nhận đã đọc thông báo / mệnh lệnh của từng user.
model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation("AnnouncementReader", fields: [userId], references: [id])

  @@unique([announcementId, userId])
}

model ForumPost {
  id              String    @id @default(cuid())
  title           String
  content         String
  category        String    @default("DISCUSSION")
  tags            String[]
  attachments     String[]
  targetPositions String[]  @default([])
  isPinned        Boolean   @default(false)
  closeSummary    String?
  closedAt        DateTime?
  closedById      String?
  authorId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author  User            @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies ForumReply[]
  likes   ForumPostLike[]
}

model ForumReply {
  id            String   @id @default(cuid())
  postId        String
  parentReplyId String?
  content       String
  attachments   String[]
  authorId      String
  createdAt     DateTime @default(now())

  post         ForumPost        @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentReply  ForumReply?      @relation("ForumReplyThread", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies ForumReply[]     @relation("ForumReplyThread")
  author       User             @relation("ForumReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  likes        ForumReplyLike[]

  @@index([parentReplyId])
}

model ForumPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation("ForumPostLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model ForumReplyLike {
  id        String   @id @default(cuid())
  replyId   String
  userId    String
  createdAt DateTime @default(now())

  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User       @relation("ForumReplyLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
  @@index([userId])
}

model OperationEvent {
  id          String   @id @default(cuid())
  type        String // DRILL_INCIDENT, DRILL_FIRE, OTHER
  title       String
  date        DateTime
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("OpCreatedBy", fields: [createdById], references: [id])

  @@index([date])
  @@index([createdById])
}

enum Role {
  ADMIN
  MANAGER
  SUPERVISOR
  TECHNICIAN
  VIEWER
}

enum ActivityLogCategory {
  SYSTEM
  SECURITY
  ATTENDANCE
  USER
}

model Shift {
  id                 String    @id @default(cuid())
  date               DateTime
  shiftType          ShiftType
  unit               String // "Vận hành 1", "Vận hành 2"
  isAttendanceLocked Boolean   @default(false) @map("is_attendance_locked")

  assignments ShiftAssignment[]
  checkIns    CheckIn[]
  handovers   ShiftHandover[]

  @@index([date, shiftType])
  @@index([unit, date])
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

model ShiftAssignment {
  id            String  @id @default(cuid())
  shiftId       String
  userId        String
  positionLabel String // display label in org chart
  parentId      String? // for org chart hierarchy
  isApproved    Boolean @default(false)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([shiftId])
  @@index([userId])
  @@index([parentId])
}

enum ShiftPositionType {
  SINGLE
  S1_S2
}

enum ShiftSlot {
  S1
  S2
  FLEX
}

enum ShiftStaffingType {
  OFFICIAL
  BACKUP
  TRAINING
  TEMPORARY
  ADMINISTRATIVE
}

enum ShiftStaffingStatus {
  ACTIVE
  ENDED
}

model ShiftPositionConfig {
  id                     String             @id @default(cuid())
  name                   String             @unique
  requiredPerShift       Int?
  requiredMorningStaff   Int?
  requiredAfternoonStaff Int?
  requiredNightStaff     Int?
  positionType           ShiftPositionType?
  trainingRowName        String?
  showTrainingRow        Boolean            @default(false)
  isActive               Boolean            @default(true)
  createdById            String
  updatedById            String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  createdBy       User                         @relation("ShiftPositionCreatedBy", fields: [createdById], references: [id])
  updatedBy       User                         @relation("ShiftPositionUpdatedBy", fields: [updatedById], references: [id])
  assignments     ShiftStaffingAssignment[]
  rotations       PositionRotationAssignment[]
  crewRotations   CrewRotationConfig[]
  scheduleEntries ShiftScheduleEntry[]

  @@index([isActive])
}

model ShiftStaffingAssignment {
  id             String              @id @default(cuid())
  userId         String
  positionId     String
  rosterColumn   String?
  isTrainingRow  Boolean             @default(false)
  crewCode       String?
  phaseIndex     Int?
  cycleStartDate DateTime?           @db.Date
  rosterStation  ShiftSlot?
  stationCode    ShiftSlot?
  assignmentType ShiftStaffingType
  startDate      DateTime            @db.Date
  endDate        DateTime?           @db.Date
  status         ShiftStaffingStatus @default(ACTIVE)
  changeReason   String
  note           String?
  createdById    String
  updatedById    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user      User                @relation("ShiftStaffingUser", fields: [userId], references: [id])
  position  ShiftPositionConfig @relation(fields: [positionId], references: [id])
  createdBy User                @relation("ShiftStaffingCreatedBy", fields: [createdById], references: [id])
  updatedBy User                @relation("ShiftStaffingUpdatedBy", fields: [updatedById], references: [id])
  absences ShiftStaffingAbsence[]

  @@index([positionId, startDate, endDate])
  @@index([positionId, rosterColumn])
  @@index([positionId, phaseIndex])
  @@index([cycleStartDate])
  @@index([userId, assignmentType, startDate, endDate])
  @@index([status])
}

model ShiftStaffingAbsence {
  id           String   @id @default(cuid())
  assignmentId String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  reason       String
  note         String?
  createdById  String
  updatedById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment ShiftStaffingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, startDate, endDate])
  @@index([startDate, endDate])
}

model RotationTemplate {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  cycleLength  Int
  cyclePattern Json
  description  String?
  isActive     Boolean  @default(true)
  createdById  String?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy     User?                        @relation("RotationTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                        @relation("RotationTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  assignments   PositionRotationAssignment[]
  crewRotations CrewRotationConfig[]

  @@index([isActive])
}

model PositionRotationAssignment {
  id                 String    @id @default(cuid())
  positionConfigId   String
  rotationTemplateId String
  effectiveFrom      DateTime  @db.Date
  effectiveTo        DateTime? @db.Date
  reason             String
  isActive           Boolean   @default(true)
  createdById        String
  updatedById        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  positionConfig   ShiftPositionConfig @relation(fields: [positionConfigId], references: [id], onDelete: Restrict)
  rotationTemplate RotationTemplate    @relation(fields: [rotationTemplateId], references: [id], onDelete: Restrict)
  createdBy        User                @relation("PositionRotationCreatedBy", fields: [createdById], references: [id])
  updatedBy        User                @relation("PositionRotationUpdatedBy", fields: [updatedById], references: [id])

  @@index([positionConfigId, effectiveFrom, effectiveTo])
  @@index([rotationTemplateId])
}

model CrewRotationConfig {
  id                 String    @id @default(cuid())
  positionConfigId   String
  crewCode           String
  rotationTemplateId String
  cycleStartDate     DateTime  @db.Date
  effectiveFrom      DateTime  @db.Date
  effectiveTo        DateTime? @db.Date
  reason             String
  createdById        String
  updatedById        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  positionConfig   ShiftPositionConfig @relation(fields: [positionConfigId], references: [id], onDelete: Restrict)
  rotationTemplate RotationTemplate    @relation(fields: [rotationTemplateId], references: [id], onDelete: Restrict)
  createdBy        User                @relation("CrewRotationCreatedBy", fields: [createdById], references: [id])
  updatedBy        User                @relation("CrewRotationUpdatedBy", fields: [updatedById], references: [id])

  @@index([positionConfigId, crewCode, effectiveFrom, effectiveTo])
  @@index([rotationTemplateId])
}

enum StaffingChangeType {
  ASSIGN_POSITION
  REMOVE_POSITION
  TRANSFER_POSITION
  MOVE_TO_OFFICE
  CHANGE_CREW
  CHANGE_STATION
}

model StaffingChangeEvent {
  id               String             @id @default(cuid())
  employeeId       String
  changeType       StaffingChangeType
  sourcePositionId String?
  targetPositionId String?
  effectiveDate    DateTime           @db.Date
  reason           String
  createdById      String
  createdAt        DateTime           @default(now())

  createdBy User @relation("StaffingChangeCreatedBy", fields: [createdById], references: [id])

  @@index([effectiveDate])
  @@index([sourcePositionId, targetPositionId])
  @@index([employeeId])
}

enum ShiftScheduleVersionStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  SUPERSEDED
}

enum ShiftScheduleEntrySource {
  GENERATED
  MANUAL
}

model ShiftScheduleVersion {
  id                 String                     @id @default(cuid())
  unit               String
  year               Int
  month              Int
  versionNumber      Int
  status             ShiftScheduleVersionStatus @default(DRAFT)
  generatedFromDate  DateTime                   @db.Date
  basedOnVersionId   String?
  generationReason   String
  generationWarnings Json?
  createdById        String
  approvedById       String?
  createdAt          DateTime                   @default(now())
  approvedAt         DateTime?
  publishedAt        DateTime?

  basedOnVersion  ShiftScheduleVersion?  @relation("ScheduleVersionLineage", fields: [basedOnVersionId], references: [id], onDelete: SetNull)
  derivedVersions ShiftScheduleVersion[] @relation("ScheduleVersionLineage")
  createdBy       User                   @relation("ScheduleVersionCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?                  @relation("ScheduleVersionApprovedBy", fields: [approvedById], references: [id])
  entries         ShiftScheduleEntry[]

  @@unique([unit, year, month, versionNumber])
  @@index([year, month, status])
}

model ShiftScheduleEntry {
  id                String                   @id @default(cuid())
  scheduleVersionId String
  date              DateTime                 @db.Date
  shiftType         ShiftType
  positionConfigId  String
  stationCode       ShiftSlot?
  employeeId        String
  source            ShiftScheduleEntrySource @default(GENERATED)
  isLocked          Boolean                  @default(false)
  note              String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  scheduleVersion ShiftScheduleVersion @relation(fields: [scheduleVersionId], references: [id], onDelete: Cascade)
  positionConfig  ShiftPositionConfig  @relation(fields: [positionConfigId], references: [id], onDelete: Restrict)

  @@unique([scheduleVersionId, date, shiftType, positionConfigId, employeeId])
  @@index([scheduleVersionId, date, shiftType])
  @@index([employeeId, date])
}

model CheckIn {
  id         String    @id @default(cuid())
  userId     String
  shiftId    String
  checkInAt  DateTime?
  checkOutAt DateTime?
  status     String // PRESENT, ABSENT, LATE
  note       String?
  approvedBy String?

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shiftId])
  @@index([status])
}

model ShiftHandover {
  id         String   @id @default(cuid())
  shiftId    String
  fromUserId String
  toUserId   String
  handoverAt DateTime
  notes      String?
  issues     String? // outstanding issues passed over

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model RepairLog {
  id           String       @id @default(cuid())
  deviceSeq    String
  machine      String       @default("COMMON") // S1 | S2 | COMMON; cây thiết bị dùng chung theo deviceSeq
  title        String
  description  String
  symptom      String?
  cause        String?
  action       String
  result       String?
  startedAt    DateTime
  completedAt  DateTime?
  status       RepairStatus @default(OPEN)
  priority     Priority     @default(MEDIUM)
  cost         Float?
  downtime     Int? // minutes
  createdById  String
  approvedById String?
  attachments  String[] // file URLs
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  device     EquipmentNode @relation(fields: [deviceSeq], references: [seq], onDelete: Cascade)
  createdBy  User          @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy User?         @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([deviceSeq])
  @@index([deviceSeq, machine])
  // Index prefix cho truy vấn cả nhánh cây: WHERE deviceSeq LIKE '1.2.%'
  @@index([deviceSeq(ops: raw("text_pattern_ops"))], map: "repairlog_deviceseq_prefix")
  @@index([deviceSeq, startedAt])
  @@index([status])
  @@index([createdById])
  @@index([startedAt])
}

enum RepairStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Material {
  id           String   @id @default(cuid())
  code         String
  erpCodes     String[] @default([])
  name         String
  unit         String
  quantity     Int      @default(0)
  minStock     Int      @default(0)
  location     String?
  system       String? // hệ thống thiết bị: Lò Hơi, Máy Nghiền, ESP, FGD...
  category     String? // loại vật tư: Dầu bôi trơn, Bi nghiền than, Lõi lọc dầu, Thiết bị C&I, Vật tư tiêu hao
  machine      String   @default("COMMON") // tổ máy sở hữu danh mục: S1 | S2 | COMMON
  imageUrl     String? // ảnh minh hoạ vật tư (public URL)
  documentUrl  String? // tài liệu đính kèm (PDF hoặc link)
  documentName String? // tên file tài liệu đính kèm
  supplier     String? // tái dùng làm "Định kỳ thay thế"
  unitPrice    Float?
  note         String? // "Ghi chú"
  createdAt    DateTime @default(now())

  deviceMaterials EquipmentMaterial[]
  replacements    MaterialReplacement[]
  ticketItems     MaterialTicketItem[]

  @@unique([code, machine])
  @@index([system])
  @@index([quantity])
  @@index([machine])
}

model ErpMaterial {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  unit      String
  erpStock  Float    @default(0)
  category  String?
  warehouse String? // Kho VTTB — kho vật tư thiết bị theo ERP
  note      String?
  isActive  Boolean  @default(true) // false = ngừng sử dụng; giữ lại để bảo toàn lịch sử phiếu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- gom nhóm theo loại dầu (module tồn kho theo loại dầu) ---
  // Import Excel ERP chỉ update name/unit/category/erpStock nên mapping đã
  // duyệt không bị reset sau mỗi lần nhập (cơ chế "học dần").
  oilTypeId        String?
  oilType          OilType?      @relation(fields: [oilTypeId], references: [id])
  mappingStatus    MappingStatus @default(UNMAPPED)
  conversionFactor Float         @default(1) // 1 unit gốc = ? baseUnit (vd 1 phuy = 209 Lít)

  // gợi ý đang chờ duyệt (null sau khi CONFIRMED/IGNORED)
  suggestedOilTypeId String?
  suggestedScore     Float?
  suggestedReason    String?

  mappingLogs OilTypeMappingLog[]

  @@index([code])
  @@index([category])
  @@index([erpStock])
  @@index([mappingStatus])
  @@index([oilTypeId])
}

// Điểm thay thế của một vật tư: vật tư này thay cho 1 thiết bị (hoặc 1 vị trí
// tự do) theo chu kỳ riêng. Dùng để theo dõi & cảnh báo thời điểm thay thế.
model MaterialReplacement {
  id               String    @id @default(cuid())
  materialId       String
  deviceSeq        String? // thiết bị theo EquipmentNode.seq (tuỳ chọn)
  machine          String    @default("COMMON") // Tổ máy: S1 | S2 | COMMON — lịch thay thế theo hồ sơ tổ máy
  location         String? // vị trí/ứng dụng tự do (tuỳ chọn) — dùng khi không gắn thiết bị
  system           String? // hệ thống thiết bị (mặc định theo vật tư), vd "Máy Nghiền"
  quantity         Int       @default(1) // dung tích/số lượng cần thay CHO MỖI thiết bị (theo ĐVT của vật tư)
  deviceCount      Int       @default(1) // số lượng thiết bị tại điểm này
  managingPosition String? // cương vị quản lý (đồng bộ danh sách với form khiếm khuyết)
  intervalMonths   Int // chu kỳ thay thế (tháng); 0 = chỉ khai báo, không theo dõi lịch
  intervalNote     String? // ghi chú chu kỳ, vd "2500h"
  lastReplacedAt   DateTime? // lần thay gần nhất (user nhập)
  nextDueAt        DateTime // ngày đến hạn kế tiếp
  note             String?
  isActive         Boolean   @default(true)
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  material  Material                 @relation(fields: [materialId], references: [id], onDelete: Cascade)
  device    EquipmentNode?           @relation(fields: [deviceSeq], references: [seq], onDelete: SetNull)
  createdBy User                     @relation("MrCreatedBy", fields: [createdById], references: [id])
  logs      MaterialReplacementLog[]

  @@index([deviceSeq])
  // Index prefix cho truy vấn cả nhánh cây: WHERE deviceSeq LIKE '1.2.%'
  @@index([deviceSeq(ops: raw("text_pattern_ops"))], map: "matrep_deviceseq_prefix")
  @@index([materialId])
  @@index([system])
  @@index([isActive, nextDueAt])
  @@index([createdById])
}

// Lịch sử mỗi lần thay thế vật tư tại một điểm thay thế.
model MaterialReplacementLog {
  id            String   @id @default(cuid())
  replacementId String
  replacedAt    DateTime @default(now())
  doneById      String
  quantity      Int?
  note          String?

  replacement MaterialReplacement @relation(fields: [replacementId], references: [id], onDelete: Cascade)
  doneBy      User                @relation("MrDoneBy", fields: [doneById], references: [id])

  @@index([replacementId])
  // Lịch sử "các lần thay tại điểm X, mới nhất trước" đọc thẳng từ index.
  @@index([replacementId, replacedAt(sort: Desc)])
  @@index([doneById])
  @@index([replacedAt])
}

model EquipmentMaterial {
  id         String   @id @default(cuid())
  deviceSeq  String
  machine    String   @default("COMMON") // Tổ máy: S1 | S2 | COMMON — vật tư dùng theo hồ sơ tổ máy trên cây chung
  materialId String
  quantity   Int
  usedAt     DateTime @default(now())
  note       String?

  device   EquipmentNode @relation(fields: [deviceSeq], references: [seq], onDelete: Cascade)
  material Material      @relation(fields: [materialId], references: [id])

  @@index([deviceSeq])
  // Lịch sử "vật tư đã dùng cho thiết bị X, mới nhất trước" đọc thẳng từ index.
  @@index([deviceSeq, usedAt(sort: Desc)])
  @@index([materialId])
}

// Khiếm khuyết thiết bị (Defect) — phiếu ghi nhận khiếm khuyết theo tổ máy/hệ thống.
model Defect {
  id                      String    @id @default(cuid())
  unit                    String // Tổ máy: S1 | S2
  deviceSeq               String? // Khóa liên kết chuẩn với cây thiết bị (EquipmentNode.seq)
  device                  String? // Thiết bị (mã thiết bị) — giữ lại tạm để tương thích dữ liệu cũ
  system                  String? // Cương vị (chức vụ phụ trách)
  severity                String? // Mức độ: "1".."4"
  severityCriteria        String[] @default([]) // Các ID tiêu chí chi tiết đã chọn theo mức độ
  condition               String? // Điều kiện thực hiện: A | B
  fireSafetyImpact        String? // Ảnh hưởng PCCC: Có | Không
  environmentSafetyImpact String? // Môi trường, ATVSLĐ: Có | Không
  requestType             String? // Yêu cầu: Cơ | Điện | I&C | Khác
  requestNumber           String? // Số yêu cầu
  content                 String? // Nội dung
  status                  String    @default("CHUA_XU_LY") // Tình trạng khiếm khuyết
  detectedAt              DateTime? // Ngày phát hiện
  shiftLeaderId           String? // Người giữ cương vị Trưởng ca tại thời điểm lập phiếu (không FK để giữ snapshot)
  shiftLeaderName         String? // Tên Trưởng ca snapshot, giữ nguyên nếu nhân sự đổi cương vị/tài khoản
  completedAt             DateTime? // Ngày đánh dấu "Đã xử lý" — dùng cho mốc ẩn khỏi danh sách sau 2 tuần
  note                    String? // Ghi chú
  imageUrl                String? // Ảnh cũ (giữ để tương thích dữ liệu trước khi hỗ trợ nhiều ảnh)
  images                  String[] @default([]) // Ảnh ghi nhận ban đầu, tối đa 3; chỉ áp dụng mức 1, 2
  createdById             String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  createdBy User           @relation("DefectCreatedBy", fields: [createdById], references: [id])
  node      EquipmentNode? @relation(fields: [deviceSeq], references: [seq], onDelete: SetNull)

  @@index([deviceSeq])
  // Lịch sử "khiếm khuyết của thiết bị X, mới nhất trước" đọc thẳng từ index.
  @@index([deviceSeq, createdAt(sort: Desc)])
  // Index prefix cho truy vấn cả nhánh cây: WHERE deviceSeq LIKE '1.2.%'
  @@index([deviceSeq(ops: raw("text_pattern_ops"))], map: "defect_deviceseq_prefix")
  @@index([device])
  @@index([system])
  @@index([status])
  @@index([unit, status])
  @@index([detectedAt])
  @@index([shiftLeaderId])
  @@index([createdAt])
  @@index([completedAt])
  @@index([createdById])
}

// Lịch sử xử lý khiếm khuyết theo cương vị — sinh khi một khiếm khuyết được "Hoàn thành".
// Tách rời vòng đời Defect (không đặt FK) để phiếu khiếm khuyết có thể bị ẩn/xoá sau 2 tuần
// mà lịch sử vẫn được giữ lại.
model DefectHistory {
  id              String   @id @default(cuid())
  defectId        String? // nguồn (khiếm khuyết) — không ràng buộc quan hệ
  unit            String // Tổ máy thực hiện (snapshot theo khiếm khuyết)
  deviceSeq       String? // Khóa liên kết chuẩn với cây thiết bị (EquipmentNode.seq) — dùng lọc quyền/nhánh bằng SQL
  device          String? // Thiết bị (mã thiết bị) — snapshot text, giữ lại khi node bị xóa
  system          String? // Cương vị (snapshot theo khiếm khuyết)
  requestType     String? // PCT (loại yêu cầu: Cơ | Điện | Hóa | …) — đồng bộ "Yêu Cầu"
  workOrderNumber String? // Số phiếu công tác thực hiện
  performedAt     DateTime // Ngày thực hiện
  result          String? // Kết quả thực hiện
  content         String? // Nội dung khiếm khuyết (snapshot)
  requestNumber   String? // Số yêu cầu (snapshot)
  images          String[] // Hình ảnh (tối đa 3)
  createdById     String
  createdAt       DateTime @default(now())

  createdBy User           @relation("DefectHistoryCreatedBy", fields: [createdById], references: [id])
  node      EquipmentNode? @relation(fields: [deviceSeq], references: [seq], onDelete: SetNull)

  @@index([deviceSeq])
  // Lịch sử "của thiết bị X, mới nhất trước" đọc thẳng từ index.
  @@index([deviceSeq, performedAt(sort: Desc)])
  // Index prefix cho truy vấn cả nhánh cây: WHERE deviceSeq LIKE '1.2.%'
  @@index([deviceSeq(ops: raw("text_pattern_ops"))], map: "defecthistory_deviceseq_prefix")
  @@index([device])
  @@index([system])
  @@index([performedAt])
  @@index([unit, performedAt])
  @@index([createdById])
}

model AuditLog {
  id        String              @id @default(cuid())
  userId    String
  action    String // e.g. "CREATE_DEVICE", "DELETE_REPAIR"
  category  ActivityLogCategory @default(USER)
  entity    String // e.g. "Device", "RepairLog"
  entityId  String?
  detail    String?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SystemAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String
  actorName     String
  action        String
  targetType    String
  targetId      String?
  beforeData    Json?
  afterData     Json?
  changedFields String[]
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId])
  @@index([action])
  @@map("system_audit_logs")
}

// Chấm công hành chính: nhóm đi công tác hành chính (HC) theo ngày.
model HcGroup {
  id          String   @id @default(cuid())
  date        DateTime // ngày chấm công
  content     String // nội dung đi hành chính
  hours       Int      @default(8) // số giờ chấm công mặc định của nhóm
  period      String?  @default("FULL_DAY") // FULL_DAY | MORNING | AFTERNOON | MORNING_OFF
  unit        String?
  createdById String // chủ trì
  createdAt   DateTime @default(now())

  createdBy User        @relation("HcGroupCreator", fields: [createdById], references: [id])
  members   HcCheckIn[]

  @@index([date])
  @@index([createdById])
}

model HcCheckIn {
  id                 String   @id @default(cuid())
  groupId            String
  userId             String
  hours              Int      @default(8)
  isApproved         Boolean  @default(false)
  note               String?
  isRegistered       Boolean  @default(false)
  registrationStatus String   @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  cancellationReason String?
  rejectionCount     Int      @default(0)
  handledById        String?
  handledByName      String?
  handledAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  group HcGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User    @relation("HcCheckInUser", fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([isApproved])
  @@index([registrationStatus])
}

// Tài liệu số (quy trình, sơ đồ P&ID, lưu trữ…). Bảng được tạo/đồng bộ bằng raw
// SQL trong app/api/documents/route.ts (ensureDigitalDocumentTable); khai báo ở
// đây để db push không đề nghị xoá. attachmentUrls lưu JSON (mảng data URL) dạng text.
model DigitalDocument {
  id               String    @id
  category         String
  title            String
  decisionNumber   String?
  issueDate        DateTime?
  documentUrl      String
  managingPosition String?
  managementBlock  String?
  procedureType    String?
  reason           String?
  progress         String?
  note             String?
  attachmentUrls   String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())

  @@index([category, updatedAt(sort: Desc)])
}

// Cấu hình ma trận phân quyền (RBAC) do ADMIN chỉnh trong /admin/roles. Bảng được
// tạo bằng raw SQL trong app/api/rbac/route.ts; value lưu JSON cấu hình dạng text.
model RbacConfig {
  key         String   @id
  value       String
  updatedById String?
  updatedAt   DateTime @default(now())
}

// Thông báo hệ thống (message box giữa màn hình do Quản trị phát). Bảng được
// tạo/đồng bộ bằng raw SQL trong app/api/broadcast/route.ts; khai báo ở đây để
// db push không đề nghị xoá.
model SystemBroadcast {
  id            String   @id
  title         String
  body          String
  isActive      Boolean  @default(true)
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
}

// Bộ đếm ngày vận hành an toàn theo tổ máy (hiển thị trên dashboard). Bảng được
// tạo/đồng bộ bằng raw SQL trong app/api/safe-operation/route.ts; khai báo ở đây
// để db push / migrate diff không đề nghị xoá (tránh mất mốc ngày vận hành an toàn).
model SafeOperationSetting {
  id          String    @id
  unit        String    @unique
  startedAt   DateTime?
  pausedAt    DateTime?
  updatedAt   DateTime  @default(now())
  updatedById String?
}

// Cây danh mục thiết bị (nhập từ DM_ThietBi.xlsx). Phân cấp dựa trên "Số thứ tự"
// dạng chấm (vd "1.1.1" là cha của "1.1.1.1"). Tách riêng khỏi Device vận hành:
// khóa duy nhất là `seq` (mã thiết bị `code` có thể trùng giữa các node).
model EquipmentNode {
  id           String   @id @default(cuid())
  // seq = MÃ THIẾT BỊ đầy đủ (fullCode), vd "DH1.S1.5.1.1" — nguồn chuẩn ổn định để dựng
  // cây (materialized path) và là khóa nghiệp vụ (repair/defect/vật tư/QR tham chiếu qua đây).
  // KHÔNG dùng "Số thứ tự" (số vị trí, không ổn định khi đánh lại).
  seq          String   @unique
  externalId   String?  @unique // Assetid (ERP) — khóa ĐỐI SOÁT khi đồng bộ/nhập lại; ổn định tuyệt đối
  parentSeq    String? // Mã thiết bị của cha (tổ tiên gần nhất trong phạm vi); null nếu là gốc
  code         String // = seq (Mã thiết bị đầy đủ) — giữ bất biến code==seq mà nghiệp vụ đang dựa vào
  name         String // tên thiết bị
  kks          String? // mã KKS
  drawing      String? // bản vẽ liên quan
  depth        Int // số đoạn của seq (1..n)
  sort         Int // thứ tự ổn định theo file nguồn
  childCount   Int      @default(0) // số con trực tiếp (denormalize) — cây lazy biết hasChildren mà không cần query
  searchText   String   @default("") // name + kks + code đã bỏ dấu/lowercase — tìm kiếm không dấu phía server
  // Người dùng tự bổ sung khi sửa thẻ thiết bị (tách khỏi dữ liệu nhập từ Excel).
  attachedInfo String? // thông tin thêm
  documentUrl  String? // tài liệu đính kèm (link)
  imageUrl     String? // 1 hình ảnh (base64 hoặc URL)
  // true nếu node do đồng bộ khi TẠO MỚI thiết bị sinh ra (seq không có trong danh mục gốc).
  // Dùng để xóa node theo khi xóa Device, mà không đụng node danh mục nhập từ Excel.
  deviceSynced Boolean  @default(false)
  createdAt    DateTime @default(now())

  repairLogs           RepairLog[]
  deviceMaterials      EquipmentMaterial[]
  materialReplacements MaterialReplacement[]
  defects              Defect[]
  defectHistories      DefectHistory[]
  ticketItems          MaterialTicketItem[]
  qrCards              DeviceQrCard[]
  profiles             EquipmentProfile[]

  @@index([parentSeq])
  @@index([parentSeq, sort])
  @@index([code])
  @@index([depth])
  @@index([kks])
  @@index([name])
}

// Hồ sơ theo TỔ MÁY trên cây thiết bị dùng chung (phương án S2): một nút có thể có hồ sơ
// S1 / S2 / COMMON. Bảng THƯA — chỉ tạo dòng khi bấm "Tạo hồ sơ S2 từ S1" hoặc khi một
// tổ máy cần override thông tin riêng. Mã S2 (DH1.S1→DH1.S2) và KKS S2 (tiền tố 10→20)
// là DẪN XUẤT từ node (lib/equipment-units.ts) — chỉ lưu tại đây khi người dùng sửa khác đi.
// Dữ liệu nghiệp vụ KHÔNG nằm ở đây: repair/defect/vật tư/QR phân tổ máy bằng cột
// machine/unit trên chính bảng nghiệp vụ (deviceSeq vẫn trỏ node → giữ lọc quyền theo nhánh).
model EquipmentProfile {
  id           String   @id @default(cuid())
  nodeSeq      String // EquipmentNode.seq
  machine      String // "S1" | "S2" | "COMMON"
  kks          String? // override KKS (mặc định dẫn xuất: S2 = tiền tố 10→20)
  name         String? // override tên nếu tổ máy đặt khác
  attachedInfo String?
  documentUrl  String?
  imageUrl     String?
  createdById  String? // id người tạo (không FK — đã có audit log)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  node EquipmentNode @relation(fields: [nodeSeq], references: [seq], onDelete: Cascade)

  @@unique([nodeSeq, machine])
  @@index([machine])
}

// Thiết bị được CHỌN tạo thẻ QR ở tab "Thẻ" (chỉ thiết bị quan trọng — không sinh
// thẻ cho toàn bộ ~6500 node lá). Xoá node thiết bị thì thẻ tự mất theo (cascade).
model DeviceQrCard {
  id          String   @id @default(cuid())
  deviceSeq   String // EquipmentNode.seq của thiết bị (node lá)
  machine     String   @default("COMMON") // Tổ máy sở hữu thẻ: S1 | S2 | COMMON — mỗi tổ máy 1 thẻ QR riêng trên cùng nút
  createdById String? // id người tạo (không FK — giữ nhẹ, đã có audit log)
  createdAt   DateTime @default(now())

  device EquipmentNode @relation(fields: [deviceSeq], references: [seq], onDelete: Cascade)

  @@unique([deviceSeq, machine])
}

// Phạm vi hệ thống thiết bị được gán cho từng cương vị quản lý.
// Dùng để lọc nhanh danh sách thiết bị khi tạo lịch sử sửa chữa, khiếm khuyết và vật tư.
model PositionSystemScope {
  id        String   @id @default(cuid())
  position  String
  systemSeq String
  access    String   @default("view") // Mức quyền của cương vị với hệ thống: "view" | "edit"
  createdAt DateTime @default(now())

  @@unique([position, systemSeq])
  @@index([position])
  @@index([systemSeq])
}

// Metadata phân loại nhánh thiết bị. Không tham gia tính quyền xem/sửa.
// Quyền thiết bị chỉ lấy từ PositionSystemScope (ma trận phân quyền).
model EquipmentBranchClassification {
  id               String   @id @default(cuid())
  systemSeq        String   @unique
  block            String?
  managingPosition String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([block])
  @@index([managingPosition])
}

// Ghi đè công trực ca theo từng dòng trong ngày (do người có quyền duyệt/chỉnh công đặt).
// Khóa chính gồm (userId, date, line). CRUD chạy bằng raw SQL trong app/api/shifts/timesheet/route.ts;
// khai báo ở đây để db push tạo bảng và không đề nghị xoá.
model TimesheetOverride {
  userId      String
  date        String // YYYY-MM-DD
  line        String   @default("shift1") // shift1 | shift2 | hc
  value       String
  note        String?
  updatedById String?
  updatedAt   DateTime @default(now())

  @@id([userId, date, line])
}

// Dữ liệu vòi dầu buồng đốt: 36 vòi/tổ máy (S1, S2), trạng thái khả dụng + khiếm khuyết.
model OilGun {
  id             String    @id @default(cuid())
  machine        String // "S1" | "S2"
  code           String // "D1", "E1", "A3"...
  wall           String // "REAR" (tường sau) | "FRONT" (tường trước)
  position       Int       @default(0) // thứ tự hiển thị trên sơ đồ
  status         String    @default("available") // available | unavailable
  defect         String? // (legacy) khiếm khuyết cũ 1 ô — đã tách thành defectSccn/defectScd, giữ để không mất dữ liệu
  defectSccn     String? // Khiếm khuyết SCCN (sửa chữa cơ nhiệt)
  defectScd      String? // Khiếm khuyết SCĐ (sửa chữa điện)
  forceFlame     Boolean   @default(false) // Force tín hiệu ngọn lửa vòi dầu
  // Lớp vòi than — chung vị trí với vòi dầu (Hướng A: cột song song)
  coalStatus     String    @default("available") // available | unavailable
  coalDefectNote String? // khiếm khuyết vòi than (1 ô, vì than ít)
  coalUpdatedBy  String?
  coalUpdatedAt  DateTime?
  updatedBy      String? // tên người cập nhật gần nhất
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@unique([machine, code])
  @@index([machine])
}

// Ghi chú chung cho sơ đồ vòi dầu theo từng tổ máy (S1/S2) — 1 dòng/tổ máy.
model OilGunNote {
  machine   String   @id // "S1" | "S2"
  note      String   @default("")
  updatedBy String?
  updatedAt DateTime @default(now()) @updatedAt
}

// BGTS Tuabin ngừng: bảng ghi thông số DCS theo ngày, dùng trong Thư mục lưu trữ
// > Dữ liệu tách lưới > BGTS Tuabin Ngừng. API tạo/đồng bộ bảng bằng raw SQL để
// bổ sung an toàn trên DB dev hiện có; khai báo ở đây để db push không đề nghị xoá.
model BgtsTurbineShutdownRecord {
  id                     String    @id
  unit                   String
  date                   String // YYYY-MM-DD
  dayShiftSigner         String?
  middleShiftSigner      String?
  nightShiftSigner       String?
  // Mốc xác nhận từng ca — tạo/đồng bộ bằng raw SQL trong app/api/bgts-tuabin-ngung/route.ts;
  // khai báo ở đây để migrate diff / db push không đề nghị xoá (giữ dữ liệu xác nhận).
  dayShiftConfirmedAt    DateTime?
  middleShiftConfirmedAt DateTime?
  nightShiftConfirmedAt  DateTime?
  createdById            String?
  updatedById            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now())

  rows BgtsTurbineShutdownRow[]

  @@unique([unit, date])
  @@index([date])
}

model BgtsTurbineShutdownRow {
  id                                     String @id
  recordId                               String
  timeHour                               Int
  turbineLubeOilPressure                 Float?
  shaftJackingOilPressure                Float?
  rotateSpeed                            Float?
  turningGearElectricity                 Float?
  eccentricity                           Float?
  hpMpCasingExpansionLeft                Float?
  hpMpCasingExpansionRight               Float?
  axialDisplacement                      Float?
  hpMpCasingDifferentialExpansion        Float?
  lpCasingDifferentialExpansion          Float?
  hpMainSteamValveWallTempInside         Float?
  hpMainSteamValveWallTempOutside        Float?
  hpRegulatingValveWallTempInside        Float?
  hpRegulatingValveWallTempOutside       Float?
  hpInnerCasingLowerPartTempInside       Float?
  hpInnerCasingLowerPartTempOutside      Float?
  hpExhaustOuterCasingInnerWallTempTop   Float?
  hpExhaustOuterCasingInnerWallTempLower Float?
  hpExhaustPipeTempLeft1                 Float?
  hpExhaustPipeTempLeft2                 Float?
  hpExhaustPipeTempRight1                Float?
  hpExhaustPipeTempRight2                Float?
  mpIntakeMetalTempInnerWall             Float?
  mpIntakeMetalTempOuterWall             Float?
  mpExhaustInnerWallTempTop              Float?
  mpExhaustInnerWallTempLower            Float?

  record BgtsTurbineShutdownRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@unique([recordId, timeHour])
  @@index([recordId])
}

// Phiếu thay thế vật tư (2 luồng: Đề xuất chuẩn & Ứng xử lý gấp).
model MaterialTicket {
  id             String @id @default(cuid())
  sequenceMonth  String // YYYY-MM theo giờ Việt Nam; mỗi tháng có dãy STT riêng
  sequenceNumber Int // STT cố định trong tháng, tăng liên tục theo thứ tự tạo phiếu
  type           String // "DE_XUAT" | "UNG"
  unit           String // Tổ máy: S1 | S2 | COMMON
  status         String // máy trạng thái theo type

  assignedPosition String // cương vị được giao — CHỈ cương vị này thao tác đề xuất/nhập liệu và thấy phiếu (trừ nhóm quản lý)
  materialCategory String? // Loại vật tư: "Dầu bôi trơn" | "Lọc dầu" | "Hóa chất" | "Bi nghiền"

  bbktNumber           String? // số Biên Bản Kiểm Tra (Đề xuất: nhập ở bước nghiệm thu, nếu có; Ứng: bổ sung sau PDF)
  proposalNote         String? // ghi chú khi tạo phiếu đề xuất (thay cho BBKT ở B0)
  pctNumber            String? // số PCT/LCT (nhập ở bước nghiệm thu/xuất file)
  proposalNumber       String? // số phiếu đề xuất vật tư (Thống kê nhập)
  proposalDocUrl       String? // file Word Phiếu ĐXVT (QLVT.12) trên MinIO — xuất trước khi nhập số phiếu
  proposalIssuedAt     DateTime? // Thống kê xác nhận giao phiếu ĐXVT (giữ tên cột cũ để tương thích dữ liệu)
  proposalReceiverName String? // tên VHV nhận phiếu ĐXVT khi Thống kê giao phiếu
  deliveryNoteNumber   String? // số phiếu giao hàng
  repairRequestNumber  String? // số phiếu yêu cầu sửa chữa
  completionNote       String? // thông tin xác nhận thay thế xong
  chiHuyName           String? // tên chỉ huy trực tiếp (SCCN) — in vào BBNT
  docUrl               String? // file Word BBNT trên MinIO
  bbktDocUrl           String? // file Word BBKT, tách riêng khỏi BBNT DO
  recoveryRequired     Boolean? // có vật tư thu hồi hay không
  recoveryQuantity     Int?
  recoveryReturnedAt   DateTime?
  recoveryDocUrl       String? // biên bản vật tư thu hồi (bổ sung khi có mẫu)
  recoveryDocNo        Int? // số văn bản BBTHVT đã cấp — giữ nguyên khi xuất lại biên bản
  recoveryDocNoYear    Int? // năm cấp số văn bản (dãy số reset mỗi năm)
  workStartedAt        DateTime? // thời gian ghi vào BBNT DO
  workEndedAt          DateTime?
  settledAt            DateTime? // Thống kê xác nhận đã quyết toán
  settledByName        String?
  rejectedReason       String?

  // dấu vết từng bước: id + tên hiển thị (đóng băng tại thời điểm thao tác)
  createdById           String
  createdByName         String
  proposedById          String?
  proposedByName        String?
  proposedByPosition    String?
  proposedAt            DateTime?
  confirmedById         String?
  confirmedByName       String?
  confirmedByPosition   String? // cương vị người xác nhận (hiện trong lịch sử phiếu)
  confirmedAt           DateTime? // mốc tính quy tắc 2 ngày (luồng đề xuất)
  statsById             String?
  statsByName           String?
  statsByPosition       String? // cương vị người nhập số phiếu ĐXVT
  statsAt               DateTime?
  // Bước VHV LÃNH VẬT TƯ của luồng Ứng (không tác động ERP)
  vhvReceivedQuantity   Int?
  vhvMaterialCode       String?
  vhvReceivedByName     String?
  vhvReceivedByPosition String?
  vhvReceivedAt         DateTime?
  // Bước NHẬN VẬT TƯ (NHAN_VAT_TU)
  receivedQuantity      Int? // khối lượng vật tư lãnh
  receivedMethod        String? // hình thức lãnh nhập tự do
  receiptSource         String? // ERP | EXISTING — nguồn lãnh vật tư (OUTSIDE là giá trị cũ)
  receivedById          String?
  receivedByName        String?
  receivedByPosition    String?
  receivedAt            DateTime?
  // Bước SỬ DỤNG VẬT TƯ (SU_DUNG_VAT_TU)
  usedQuantity          Int? // khối lượng vật tư sử dụng
  remainingQuantity     Int? // còn lại = lãnh − dùng (âm = dùng vượt phần lãnh, trừ vào tồn kho)
  materialUserName      String? // tên VHV trực tiếp sử dụng vật tư
  usedById              String?
  usedByName            String?
  usedByPosition        String?
  usedAt                DateTime?
  completedById         String?
  completedByName       String? // Trưởng Ca/TK xuất file — in vào Hội đồng nghiệm thu
  completedByPosition   String? // cương vị người nghiệm thu
  completedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MaterialTicketItem[]

  @@unique([sequenceMonth, sequenceNumber])
  @@index([status])
  @@index([unit, status])
  @@index([type])
  @@index([assignedPosition])
}

// Phân quyền các bước của quy trình phiếu thay thế vật tư: admin gán CƯƠNG VỊ nào
// được thao tác ở bước nào ("create" tạo phiếu/đề xuất, "confirm" xác nhận,
// "accept" nghiệm thu, "manage" sửa/xoá phiếu). Bước chưa cấu hình → dùng mặc
// định cũ (Trưởng Ca/KTV/…) để không gãy khi mới deploy.
model MaterialWorkflowRole {
  id        String   @id @default(cuid())
  step      String // mã bước trong WORKFLOW_STEPS (lib/material-workflow.ts)
  position  String // cương vị được phép thao tác bước này
  createdAt DateTime @default(now())

  @@unique([step, position])
  @@index([step])
}

// Cấp số văn bản Biên bản vật tư thu hồi (BBTHVT): tăng dần 1, 2, 3… và reset về 1
// khi sang năm mới. Mỗi năm một dòng; tăng số bằng upsert increment (atomic).
model RecoveryDocSequence {
  year  Int @id
  value Int @default(0)
}

model MaterialTicketItem {
  id                  String  @id @default(cuid())
  ticketId            String
  materialId          String
  erpCode             String?
  erpName             String? // tên vật tư ERP đóng băng khi chọn mã, dùng cho biên bản
  deviceSeq           String? // thiết bị theo EquipmentNode.seq; phiếu đề xuất mới có thể nhập tay tên thiết bị
  deviceNameManual    String?
  quantity            Int     @default(1)
  replacementQuantity Int? // số lượng thay thế do cương vị phân giao nhập ở luồng Ứng

  ticket   MaterialTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  material Material       @relation(fields: [materialId], references: [id])
  device   EquipmentNode? @relation(fields: [deviceSeq], references: [seq], onDelete: SetNull)

  @@index([ticketId])
  @@index([deviceSeq])
}

// Lưu các mốc thời gian cho phần Vận hành an toàn (Safe Operation).
// Các CHECK constraint và partial unique index cho "continuous" được áp bằng
// prisma/add_safe_op_events.sql vì Prisma chưa biểu diễn được partial index.
model SafeOperationEvent {
  id        String    @id @default(cuid())
  unit      String // "S1" hoặc "S2"
  category  String // "continuous", "standby", "maintenance", "incident"
  startedAt DateTime
  endedAt   DateTime?
  reason    String?
  isAdded   Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([unit, category])
  @@index([createdAt])
}

// ---------------------------------------------------------------------
// GOM NHÓM VẬT TƯ DẦU — Phương án 3 (Hybrid: tự động gợi ý + người duyệt)
// Gom các mã vật tư ERP cùng loại dầu → tổng tồn kho theo loại + cảnh báo
// dưới ngưỡng. Mapping đã duyệt lưu vĩnh viễn (cơ chế "học dần").
// ---------------------------------------------------------------------

enum MappingStatus {
  UNMAPPED // mã mới, chưa chạy matching hoặc không tìm được gợi ý
  SUGGESTED // đã có gợi ý, chờ người duyệt
  CONFIRMED // đã gom nhóm (mapping vĩnh viễn)
  IGNORED // không phải dầu / không cần gom (không hỏi lại)
}

model OilType {
  id        String  @id @default(cuid())
  code      String  @unique // "T32", "VG46", "15W40", "LOC-TB"...
  name      String // "Dầu tuabin T32", "Lõi lọc dầu tuabin"...
  baseUnit  String // đơn vị chuẩn để cộng tồn: "Lít", "Cái", "Kg", "Viên"
  minStock  Float? // ngưỡng cảnh báo đề xuất nhập (theo baseUnit)
  onHandQty Float   @default(0) // "Hiện có" — số đếm thực tế tại kho, nhập tay trên UI
  note      String?
  // Loại vật tư của nhóm — khớp Material.category / ErpMaterial.category:
  // "Dầu bôi trơn" | "Lõi lọc dầu" | "Hóa Chất" | "Bi Nghiền Than"
  category  String  @default("Dầu bôi trơn")

  materials ErpMaterial[]
  logs      OilTypeMappingLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("oil_types")
}

// Audit trail: ai gom mã nào vào nhóm nào, lúc nào, vì sao.
// Phục vụ truy vết theo CS-ATTT-KTAT-21 / ISO 27001.
model OilTypeMappingLog {
  id         String      @id @default(cuid())
  materialId String
  material   ErpMaterial @relation(fields: [materialId], references: [id])
  oilTypeId  String?
  oilType    OilType?    @relation(fields: [oilTypeId], references: [id])

  action String // SUGGESTED | CONFIRMED | CHANGED | REMOVED | IGNORED
  score  Float?
  reason String?
  userId String? // id user NextAuth thực hiện thao tác (null = hệ thống)

  createdAt DateTime @default(now())

  @@index([materialId])
  @@map("oil_type_mapping_logs")
}
