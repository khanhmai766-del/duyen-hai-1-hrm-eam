// PowerPlant HRM & EAM — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  employeeId   String   @unique
  email        String   @unique
  phone        String?
  avatarUrl    String?
  signatureUrl String? // chữ ký số: PNG nền trong suốt (base64) hoặc URL ngoài
  passwordHash String
  role         Role     @default(VIEWER)
  position     String? // e.g. "Lò trưởng S1", "I&C", "Trưởng ca"
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  checkIns         CheckIn[]
  shiftAssignments ShiftAssignment[]
  repairLogs       RepairLog[]       @relation("CreatedBy")
  approvedLogs     RepairLog[]       @relation("ApprovedBy")
  auditLogs        AuditLog[]
  operationEvents  OperationEvent[]  @relation("OpCreatedBy")
  hcGroups          HcGroup[]          @relation("HcGroupCreator")
  hcCheckIns        HcCheckIn[]        @relation("HcCheckInUser")
  announcements     Announcement[]     @relation("AnnouncementCreator")
  announcementReads AnnouncementRead[] @relation("AnnouncementReader")
  materialReplacements    MaterialReplacement[]    @relation("MrCreatedBy")
  materialReplacementLogs MaterialReplacementLog[] @relation("MrDoneBy")
  defects                 Defect[]                 @relation("DefectCreatedBy")
  defectHistories         DefectHistory[]          @relation("DefectHistoryCreatedBy")
  webAuthnCredentials     WebAuthnCredential[]
  forumPosts              ForumPost[]              @relation("ForumPostAuthor")
  forumReplies            ForumReply[]             @relation("ForumReplyAuthor")
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  userId       String
  deviceName   String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Bảng tin nội bộ: bài đăng do Quản trị (ADMIN) tạo, mọi người chỉ xem.
model Announcement {
  id          String   @id @default(cuid())
  category       String   @default("BULLETIN") // BULLETIN (bảng tin) | ORDER (mệnh lệnh sản xuất)
  classification String? // phân loại: Vận hành | An toàn vệ sinh lao động
  stt            String? // số thứ tự (tuỳ chọn), vd "01"
  title       String
  body        String
  pinned      Boolean  @default(false)
  orderedBy   String? // "Theo lệnh" — tên quản đốc / phó quản đốc ra lệnh
  linkUrl     String? // optional website link
  fileUrl     String? // optional attached PDF (public URL)
  fileName    String? // original PDF file name
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User               @relation("AnnouncementCreator", fields: [createdById], references: [id])
  reads     AnnouncementRead[]
}

// Xác nhận đã đọc thông báo / mệnh lệnh của từng user.
model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation("AnnouncementReader", fields: [userId], references: [id])

  @@unique([announcementId, userId])
}

model ForumPost {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("DISCUSSION")
  tags        String[]
  attachments String[]
  isPinned    Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author  User         @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies ForumReply[]
}

model ForumReply {
  id          String   @id @default(cuid())
  postId      String
  content     String
  attachments String[]
  authorId    String
  createdAt   DateTime @default(now())

  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User      @relation("ForumReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model OperationEvent {
  id          String   @id @default(cuid())
  type        String // DRILL_INCIDENT, DRILL_FIRE, OTHER
  title       String
  date        DateTime
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("OpCreatedBy", fields: [createdById], references: [id])
}

enum Role {
  ADMIN
  SUPERVISOR
  TECHNICIAN
  VIEWER
}

model Shift {
  id        String    @id @default(cuid())
  date      DateTime
  shiftType ShiftType
  unit      String // "Vận hành 1", "Vận hành 2"

  assignments ShiftAssignment[]
  checkIns    CheckIn[]
  handovers   ShiftHandover[]
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

model ShiftAssignment {
  id            String  @id @default(cuid())
  shiftId       String
  userId        String
  positionLabel String // display label in org chart
  parentId      String? // for org chart hierarchy
  isApproved    Boolean @default(false)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

model CheckIn {
  id         String    @id @default(cuid())
  userId     String
  shiftId    String
  checkInAt  DateTime?
  checkOutAt DateTime?
  status     String // PRESENT, ABSENT, LATE
  note       String?
  approvedBy String?

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model ShiftHandover {
  id         String   @id @default(cuid())
  shiftId    String
  fromUserId String
  toUserId   String
  handoverAt DateTime
  notes      String?
  issues     String? // outstanding issues passed over

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model RepairLog {
  id           String       @id @default(cuid())
  deviceSeq    String
  title        String
  description  String
  symptom      String?
  cause        String?
  action       String
  result       String?
  startedAt    DateTime
  completedAt  DateTime?
  status       RepairStatus @default(OPEN)
  priority     Priority     @default(MEDIUM)
  cost         Float?
  downtime     Int? // minutes
  createdById  String
  approvedById String?
  attachments  String[] // file URLs
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  device     EquipmentNode @relation(fields: [deviceSeq], references: [seq], onDelete: Cascade)
  createdBy  User   @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy User?  @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([deviceSeq])
}

enum RepairStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Material {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  unit      String
  quantity  Int      @default(0)
  minStock  Int      @default(0)
  location  String?
  system    String? // hệ thống thiết bị: Lò Hơi, Máy Nghiền, ESP, FGD...
  imageUrl  String? // ảnh minh hoạ vật tư (public URL)
  supplier  String? // tái dùng làm "Định kỳ thay thế"
  unitPrice Float?
  note      String? // "Ghi chú"
  createdAt DateTime @default(now())

  deviceMaterials EquipmentMaterial[]
  replacements    MaterialReplacement[]
}

// Điểm thay thế của một vật tư: vật tư này thay cho 1 thiết bị (hoặc 1 vị trí
// tự do) theo chu kỳ riêng. Dùng để theo dõi & cảnh báo thời điểm thay thế.
model MaterialReplacement {
  id             String    @id @default(cuid())
  materialId     String
  deviceSeq      String? // thiết bị theo EquipmentNode.seq (tuỳ chọn)
  location       String? // vị trí/ứng dụng tự do (tuỳ chọn) — dùng khi không gắn thiết bị
  system         String? // hệ thống thiết bị (mặc định theo vật tư), vd "Máy Nghiền"
  quantity       Int      @default(1) // số lượng cần thay tại điểm này (theo ĐVT của vật tư)
  intervalMonths Int // chu kỳ thay thế (tháng)
  intervalNote   String? // ghi chú chu kỳ, vd "2500h"
  lastReplacedAt DateTime? // lần thay gần nhất (user nhập)
  nextDueAt      DateTime // ngày đến hạn kế tiếp
  note           String?
  isActive       Boolean   @default(true)
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  material  Material                 @relation(fields: [materialId], references: [id], onDelete: Cascade)
  device    EquipmentNode?           @relation(fields: [deviceSeq], references: [seq], onDelete: SetNull)
  createdBy User                     @relation("MrCreatedBy", fields: [createdById], references: [id])
  logs      MaterialReplacementLog[]

  @@index([deviceSeq])
}

// Lịch sử mỗi lần thay thế vật tư tại một điểm thay thế.
model MaterialReplacementLog {
  id            String   @id @default(cuid())
  replacementId String
  replacedAt    DateTime @default(now())
  doneById      String
  quantity      Int?
  note          String?

  replacement MaterialReplacement @relation(fields: [replacementId], references: [id], onDelete: Cascade)
  doneBy      User                @relation("MrDoneBy", fields: [doneById], references: [id])
}

model EquipmentMaterial {
  id         String   @id @default(cuid())
  deviceSeq  String
  materialId String
  quantity   Int
  usedAt     DateTime @default(now())
  note       String?

  device   EquipmentNode @relation(fields: [deviceSeq], references: [seq], onDelete: Cascade)
  material Material      @relation(fields: [materialId], references: [id])

  @@index([deviceSeq])
  @@index([materialId])
}

// Khiếm khuyết thiết bị (Defect) — phiếu ghi nhận khiếm khuyết theo tổ máy/hệ thống.
model Defect {
  id            String    @id @default(cuid())
  unit          String // Tổ máy: S1 | S2
  device        String? // Thiết bị (mã thiết bị)
  system        String? // Cương vị (chức vụ phụ trách)
  severity      String? // Mức độ: "1".."4"
  condition     String? // Điều kiện thực hiện: A | B
  fireSafetyImpact       String? // Ảnh hưởng PCCC: Có | Không
  environmentSafetyImpact String? // Môi trường, ATVSLĐ: Có | Không
  requestType   String? // Yêu cầu: Cơ | Điện | I&C | Khác
  requestNumber String? // Số yêu cầu
  content       String? // Nội dung
  status        String    @default("CHUA_XU_LY") // Tình trạng khiếm khuyết
  detectedAt    DateTime? // Ngày phát hiện
  completedAt   DateTime? // Ngày đánh dấu "Đã xử lý" — dùng cho mốc ẩn khỏi danh sách sau 2 tuần
  note          String? // Ghi chú
  imageUrl      String? // Hình ảnh
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdBy User @relation("DefectCreatedBy", fields: [createdById], references: [id])
}

// Lịch sử xử lý khiếm khuyết theo cương vị — sinh khi một khiếm khuyết được "Hoàn thành".
// Tách rời vòng đời Defect (không đặt FK) để phiếu khiếm khuyết có thể bị ẩn/xoá sau 2 tuần
// mà lịch sử vẫn được giữ lại.
model DefectHistory {
  id              String   @id @default(cuid())
  defectId        String? // nguồn (khiếm khuyết) — không ràng buộc quan hệ
  unit            String // Tổ máy thực hiện (snapshot theo khiếm khuyết)
  device          String? // Thiết bị (mã thiết bị) — đồng bộ danh mục Thiết bị
  system          String? // Cương vị (snapshot theo khiếm khuyết)
  requestType     String? // PCT (loại yêu cầu: Cơ | Điện | Hóa | …) — đồng bộ "Yêu Cầu"
  workOrderNumber String? // Số phiếu công tác thực hiện
  performedAt     DateTime // Ngày thực hiện
  result          String? // Kết quả thực hiện
  content         String? // Nội dung khiếm khuyết (snapshot)
  requestNumber   String? // Số yêu cầu (snapshot)
  images          String[] // Hình ảnh (tối đa 3)
  createdById     String
  createdAt       DateTime @default(now())

  createdBy User @relation("DefectHistoryCreatedBy", fields: [createdById], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // e.g. "CREATE_DEVICE", "DELETE_REPAIR"
  entity    String // e.g. "Device", "RepairLog"
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// Chấm công hành chính: nhóm đi công tác hành chính (HC) theo ngày.
model HcGroup {
  id          String   @id @default(cuid())
  date        DateTime // ngày chấm công
  content     String   // nội dung đi hành chính
  hours       Int      @default(8) // số giờ chấm công mặc định của nhóm
  unit        String?
  createdById String   // chủ trì
  createdAt   DateTime @default(now())

  createdBy User        @relation("HcGroupCreator", fields: [createdById], references: [id])
  members   HcCheckIn[]
}

model HcCheckIn {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  hours      Int      @default(8)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  group HcGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User    @relation("HcCheckInUser", fields: [userId], references: [id])

  @@unique([groupId, userId])
}

// Tài liệu số (quy trình, sơ đồ P&ID, lưu trữ…). Bảng được tạo/đồng bộ bằng raw
// SQL trong app/api/documents/route.ts (ensureDigitalDocumentTable); khai báo ở
// đây để db push không đề nghị xoá. attachmentUrls lưu JSON (mảng data URL) dạng text.
model DigitalDocument {
  id               String   @id
  category         String
  title            String
  decisionNumber   String?
  documentUrl      String
  managingPosition String?
  managementBlock  String?
  reason           String?
  progress         String?
  note             String?
  attachmentUrls   String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  @@index([category, updatedAt(sort: Desc)])
}

// Cấu hình ma trận phân quyền (RBAC) do ADMIN chỉnh trong /admin/roles. Bảng được
// tạo bằng raw SQL trong app/api/rbac/route.ts; value lưu JSON cấu hình dạng text.
model RbacConfig {
  key         String   @id
  value       String
  updatedById String?
  updatedAt   DateTime @default(now())
}

// Thông báo hệ thống (message box giữa màn hình do Quản trị phát). Bảng được
// tạo/đồng bộ bằng raw SQL trong app/api/broadcast/route.ts; khai báo ở đây để
// db push không đề nghị xoá.
model SystemBroadcast {
  id            String   @id
  title         String
  body          String
  isActive      Boolean  @default(true)
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
}

// Cây danh mục thiết bị (nhập từ DM_ThietBi.xlsx). Phân cấp dựa trên "Số thứ tự"
// dạng chấm (vd "1.1.1" là cha của "1.1.1.1"). Tách riêng khỏi Device vận hành:
// khóa duy nhất là `seq` (mã thiết bị `code` có thể trùng giữa các node).
model EquipmentNode {
  id        String   @id @default(cuid())
  seq       String   @unique // số thứ tự, vd "1.1.1.2"
  parentSeq String? // seq cha (bỏ đoạn cuối); null nếu là gốc
  code      String // mã thiết bị (KHÔNG duy nhất)
  name      String // tên thiết bị
  kks       String? // mã KKS
  drawing   String? // bản vẽ liên quan
  depth     Int // số đoạn của seq (1..n)
  sort      Int // thứ tự ổn định theo file nguồn
  // Người dùng tự bổ sung khi sửa thẻ thiết bị (tách khỏi dữ liệu nhập từ Excel).
  attachedInfo String? // thông tin thêm
  documentUrl  String? // tài liệu đính kèm (link)
  imageUrl     String? // 1 hình ảnh (base64 hoặc URL)
  // true nếu node do đồng bộ khi TẠO MỚI thiết bị sinh ra (seq không có trong danh mục gốc).
  // Dùng để xóa node theo khi xóa Device, mà không đụng node danh mục nhập từ Excel.
  deviceSynced Boolean @default(false)
  createdAt DateTime @default(now())

  repairLogs           RepairLog[]
  deviceMaterials      EquipmentMaterial[]
  materialReplacements MaterialReplacement[]

  @@index([parentSeq])
  @@index([code])
}

// Phạm vi hệ thống thiết bị được gán cho từng cương vị quản lý.
// Dùng để lọc nhanh danh sách thiết bị khi tạo lịch sử sửa chữa, khiếm khuyết và vật tư.
model PositionSystemScope {
  id        String   @id @default(cuid())
  position  String
  systemSeq String
  access    String   @default("view") // Mức quyền của cương vị với hệ thống: "view" | "edit"
  createdAt DateTime @default(now())

  @@unique([position, systemSeq])
  @@index([position])
  @@index([systemSeq])
}
